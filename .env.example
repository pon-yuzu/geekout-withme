# ===========================================
# Geek Out With Me - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -------------------------------------------
# Supabase
# -------------------------------------------
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# -------------------------------------------
# Stripe
# -------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxx
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID=price_xxxxx
STRIPE_LINE_SUPPORT_PRICE_ID=price_xxxxx

# -------------------------------------------
# Cloudflare Workers AI
# -------------------------------------------
CF_AI_TOKEN=xxxxx
CF_ACCOUNT_ID=xxxxx

# -------------------------------------------
# Email (Resend)
# -------------------------------------------
RESEND_API_KEY=re_xxxxx

# -------------------------------------------
# Admin
# -------------------------------------------
ADMIN_EMAILS=admin@example.com

# -------------------------------------------
# Site
# -------------------------------------------
PUBLIC_SITE_URL=http://localhost:4321
# Production: PUBLIC_SITE_URL=https://uchiwai.app

# -------------------------------------------
# Voice Lounge
# -------------------------------------------
PUBLIC_VOICE_LOUNGE_ENABLED=false
VOICE_LOUNGE_ALLOWED_USERS=user1@example.com,user2@example.com

# -------------------------------------------
# Claude API (local dev)
# -------------------------------------------
CLAUDE_API_KEY=sk-ant-xxxxx
