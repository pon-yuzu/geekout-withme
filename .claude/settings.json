{
  "permissions": {
    "deny": [
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.ssh/**)",
      "Bash(cat **/.env*)",
      "Bash(source **/.env*)",
      "Bash(grep * .env*)",
      "Bash(head **/.env*)",
      "Bash(tail **/.env*)",
      "Read(**/.dev.vars*)",
      "Bash(cat **/.dev.vars*)",
      "Bash(head **/.dev.vars*)",
      "Bash(tail **/.dev.vars*)",
      "Bash(grep * .dev.vars*)",
      "Read(~/.geekout-dev-vars)",
      "Read(**/*geekout-dev-vars*)",
      "Bash(cat ~/.geekout-dev-vars)",
      "Bash(cat *geekout-dev-vars*)",
      "Bash(head ~/.geekout-dev-vars)",
      "Bash(tail ~/.geekout-dev-vars)",
      "Bash(grep * ~/.geekout-dev-vars)",
      "Bash(*readFileSync*geekout-dev-vars*)",
      "Bash(*readFileSync*.env*)",
      "Bash(*readFileSync*.dev.vars*)",
      "Bash(*dotenv*)"
    ]
  }
}
