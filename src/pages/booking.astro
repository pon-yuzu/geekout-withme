---
import Layout from '../layouts/Layout.astro';
import BookingCalendar from '../components/booking/BookingCalendar';
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';
import { getUserTier } from '../lib/tier';

const user = Astro.locals.user;
const lang = Astro.locals.lang as Lang;

if (!user) {
  return Astro.redirect('/login');
}

const supabase = Astro.locals.supabase!;
const userTier = await getUserTier(supabase, user.id);
const isPersonal = userTier === 'personal';
const pageTitle = t(lang, 'booking.title');
const canceled = Astro.url.searchParams.get('canceled');
---

<Layout title={pageTitle} user={user}>
  <section class="py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-800">{pageTitle}</h1>
        <p class="text-gray-500 text-sm mt-1">
          {isPersonal
            ? t(lang, 'booking.personalSubtitle')
            : t(lang, 'booking.selectSlot')}
        </p>
      </div>

      {canceled && (
        <div class="mb-6 p-4 bg-yellow-50 border border-yellow-200 rounded-xl text-yellow-700 text-center text-sm">
          {t(lang, 'booking.paymentCanceled')}
        </div>
      )}

      {isPersonal ? (
        <BookingCalendar
          client:load
          mode="member"
          duration={90}
          bookingType="personal"
        />
      ) : (
        <BookingCalendar
          client:load
          mode="member"
          duration={60}
          bookingType="public"
        />
      )}
    </div>
  </section>
</Layout>
