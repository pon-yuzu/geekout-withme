---
import Layout from '../../../../../layouts/Layout.astro';
import { t } from '../../../../../i18n/index';
import type { Lang } from '../../../../../i18n/index';
import { isAdmin } from '../../../../../lib/admin';
import { createClient } from '@supabase/supabase-js';

const user = Astro.locals.user;
const lang = Astro.locals.lang as Lang;
const supabase = Astro.locals.supabase;

if (!user || !supabase) {
  return Astro.redirect('/login');
}

const { slug } = Astro.params;
const admin = isAdmin(user.email, Astro.locals);
const targetUserId = admin ? (Astro.url.searchParams.get('user_id') || user.id) : user.id;

// Admin needs service role client to bypass RLS for other users' workbooks
const runtime = (Astro.locals as any).runtime;
const queryClient = (admin && targetUserId !== user.id)
  ? createClient(
      runtime?.env?.PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL,
      runtime?.env?.SUPABASE_SERVICE_ROLE_KEY || import.meta.env.SUPABASE_SERVICE_ROLE_KEY
    )
  : supabase;

const { data: workbook } = await queryClient
  .from('custom_workbooks')
  .select('*')
  .eq('user_id', targetUserId)
  .eq('slug', slug)
  .single();

if (!workbook) {
  return Astro.redirect('/my/workbook/custom');
}

// For single-page workbooks, redirect directly to content
if (workbook.total_days === 1) {
  const qs = admin && targetUserId !== user.id ? `?user_id=${targetUserId}` : '';
  return Astro.redirect(`/my/workbook/custom/${slug}/day/1${qs}`);
}

const days = Array.from({ length: workbook.total_days }, (_, i) => i + 1);

// Fetch progress
const { data: progressData } = await queryClient
  .from('custom_workbook_progress')
  .select('day_number')
  .eq('workbook_id', workbook.id)
  .eq('user_id', targetUserId);

const completedDays = new Set((progressData ?? []).map((p: any) => p.day_number));
const completedCount = completedDays.size;
const pct = Math.round((completedCount / workbook.total_days) * 100);
const adminQs = admin && targetUserId !== user.id ? `?user_id=${targetUserId}` : '';
---

<Layout title={workbook.title} user={user}>
  <section class="py-8 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <a href="/my" class="text-gray-500 hover:text-orange-500 transition-colors text-sm">
          ← {t(lang, 'myPortal.title')}
        </a>
      </div>

      <div class="text-center mb-8">
        <div
          class="w-16 h-16 rounded-2xl mx-auto mb-4 flex items-center justify-center text-white font-bold text-2xl"
          style={`background-color: ${workbook.theme_color || '#e8a4b8'}`}
        >
          {workbook.title.charAt(0)}
        </div>
        <h1 class="text-3xl font-bold mb-2">{workbook.title}</h1>
        {workbook.description && (
          <p class="text-gray-500">{workbook.description}</p>
        )}
        {workbook.navigator_name && (
          <p class="text-sm text-gray-400 mt-2">
            Navigator: {workbook.navigator_name}
          </p>
        )}

        {/* Progress bar */}
        <div class="mt-6 max-w-md mx-auto">
          <div class="flex items-center justify-between text-sm text-gray-500 mb-1">
            <span>{completedCount}/{workbook.total_days} {t(lang, 'myPortal.daysComplete')}</span>
            <span class="text-teal-500 font-medium">{pct}%</span>
          </div>
          <div class="w-full h-3 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full bg-teal-400 rounded-full transition-all" style={`width: ${pct}%`} />
          </div>
        </div>
      </div>

      <div class="grid grid-cols-5 sm:grid-cols-6 md:grid-cols-10 gap-3">
        {days.map((day) => {
          const done = completedDays.has(day);
          return (
            <a
              href={`/my/workbook/custom/${slug}/day/${day}${adminQs}`}
              class:list={[
                'aspect-square rounded-xl border-2 flex items-center justify-center font-bold text-lg transition-all hover:shadow-md relative',
                done
                  ? 'border-teal-300 bg-teal-50'
                  : 'border-gray-200 hover:border-orange-400',
              ]}
              style={`color: ${workbook.theme_color || '#e8a4b8'}`}
            >
              {day}
              {done && (
                <span class="absolute -top-1 -right-1 w-5 h-5 bg-teal-400 rounded-full flex items-center justify-center text-white text-xs">✓</span>
              )}
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
