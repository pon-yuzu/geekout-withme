---
import Layout from '../../../../../../layouts/Layout.astro';
import { Quiz } from '../../../../../../components/workbook/Quiz';
import { t } from '../../../../../../i18n/index';
import type { Lang } from '../../../../../../i18n/index';
import { createClient } from '@supabase/supabase-js';

const user = Astro.locals.user;
const lang = Astro.locals.lang as Lang;
const supabase = Astro.locals.supabase;

if (!user || !supabase) {
  return Astro.redirect('/login');
}

const { slug, num } = Astro.params;
const dayNum = parseInt(num || '0', 10);

const { data: workbook } = await supabase
  .from('custom_workbooks')
  .select('*')
  .eq('user_id', user.id)
  .eq('slug', slug)
  .single();

if (!workbook || dayNum < 1 || dayNum > workbook.total_days) {
  return Astro.redirect(`/my/workbook/custom/${slug}`);
}

const runtime = (Astro.locals as any).runtime;
const serviceRoleKey = runtime?.env?.SUPABASE_SERVICE_ROLE_KEY || import.meta.env.SUPABASE_SERVICE_ROLE_KEY;
const supabaseUrl = runtime?.env?.PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL;

let html = '';
let contentJson: any = null;
const isAdaptive = workbook.storage_path.startsWith('adaptive/');

if (isAdaptive) {
  // Fetch from adaptive_workbook_days
  const serviceClient = createClient(supabaseUrl, serviceRoleKey);
  const { data: config } = await serviceClient
    .from('student_configs')
    .select('id')
    .eq('user_id', user.id)
    .single();

  if (config) {
    const { data: dayData } = await serviceClient
      .from('adaptive_workbook_days')
      .select('content_json')
      .eq('config_id', config.id)
      .eq('day_number', dayNum)
      .eq('review_status', 'approved')
      .single();

    if (dayData?.content_json) {
      contentJson = dayData.content_json;
    }
  }
} else {
  // Fetch HTML from Storage
  const storagePath = `${workbook.storage_path}/day${dayNum}.html`;
  const storageRes = await fetch(
    `${supabaseUrl}/storage/v1/object/custom-workbooks/${storagePath}`,
    {
      headers: {
        'apikey': serviceRoleKey,
        'Authorization': `Bearer ${serviceRoleKey}`,
      },
    }
  );
  if (storageRes.ok) {
    html = await storageRes.text();
  }
}

const prevDay = dayNum > 1 ? dayNum - 1 : null;
const nextDay = dayNum < workbook.total_days ? dayNum + 1 : null;

// Check completion status (only for multi-day workbooks)
let isCompleted = false;
if (workbook.total_days > 1) {
  const { data: prog } = await supabase
    .from('custom_workbook_progress')
    .select('day_number')
    .eq('workbook_id', workbook.id)
    .eq('user_id', user.id)
    .eq('day_number', dayNum)
    .maybeSingle();
  isCompleted = !!prog;
}

function formatDetail(text: string): string {
  return text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}

function formatTips(text: string): string {
  return text.split('\n\n').filter(Boolean).map((p: string) => `<p class="mb-3 leading-relaxed">${p.trim()}</p>`).join('\n');
}
---

<Layout title={`${workbook.title} - Day ${dayNum}`} user={user}>
  <section class="py-8 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <a
          href={`/my/workbook/custom/${slug}`}
          class="text-gray-500 hover:text-orange-500 transition-colors text-sm"
        >
          ← {workbook.title}
        </a>
        <span class="text-sm text-gray-400">
          Day {dayNum} / {workbook.total_days}
        </span>
      </div>

      {contentJson ? (
        <!-- Adaptive Workbook: JSON-rendered content -->
        <div class="space-y-8">
          <!-- Main Content -->
          <div class="bg-white rounded-2xl border border-orange-100 p-6 md:p-8 shadow-sm">
            <h2 class="text-2xl font-bold text-gray-800 mb-2">{contentJson.main.title}</h2>
            <p class="text-orange-600 italic mb-4">{contentJson.main.intro}</p>
            <div id="main-text" class="text-gray-700 mb-4 whitespace-pre-line">{contentJson.main.body}</div>
            {contentJson.main.details?.length > 0 && (
              <ol id="main-details" class="space-y-1 text-gray-600 mb-4">
                {contentJson.main.details.map((d: string, i: number) => (
                  <li set:html={`${i + 1}. ${formatDetail(d)}`} />
                ))}
              </ol>
            )}
            <div class="wb-action-row">
              <button class="wb-action-btn" onclick="copyText('main-text')">📋 コピー</button>
              <button class="wb-action-btn wb-tts-btn" onclick="speakText('main-text', this)">🔊 読み上げ</button>
              <a class="wb-action-btn" href="https://www.naturalreaders.com/online/" target="_blank" rel="noopener">🔊 Natural Reader</a>
              <select class="wb-speed-select" onchange="currentSpeed=parseFloat(this.value)">
                <option value="0.7">0.7x</option>
                <option value="0.85" selected>0.85x</option>
                <option value="1">1.0x</option>
                <option value="1.2">1.2x</option>
              </select>
            </div>
          </div>

          <!-- Main Vocab -->
          {contentJson.main_vocab?.length > 0 && (
            <div class="bg-blue-50 rounded-2xl p-5">
              <h3 class="text-sm font-semibold text-blue-700 uppercase mb-3">Vocabulary</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {contentJson.main_vocab.map((v: any) => (
                  <div class="bg-white rounded-lg px-3 py-2 text-sm">
                    <span class="font-medium text-gray-800">{v.word}</span>
                    <span class="text-gray-500 ml-2">{v.meaning}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Quiz 1 -->
          {contentJson.quiz1 && (
            <Quiz client:load quiz={contentJson.quiz1} id="quiz1" />
          )}

          <!-- Review -->
          {contentJson.review && (
            <div class="bg-white rounded-2xl border border-green-100 p-6 shadow-sm">
              <div class="flex items-center gap-2 mb-3">
                <h3 class="font-semibold text-gray-800">{contentJson.review.place}</h3>
                <span class="text-sm text-gray-500">({contentJson.review.location})</span>
                <span class="text-yellow-500">{'★'.repeat(contentJson.review.stars)}</span>
              </div>
              <p id="review-text" class="text-gray-700 leading-relaxed mb-4">{contentJson.review.content}</p>
              <div class="wb-action-row">
                <button class="wb-action-btn" onclick="copyText('review-text')">📋 コピー</button>
                <button class="wb-action-btn wb-tts-btn" onclick="speakText('review-text', this)">🔊 読み上げ</button>
                <a class="wb-action-btn" href="https://www.naturalreaders.com/online/" target="_blank" rel="noopener">🔊 Natural Reader</a>
              </div>
            </div>
          )}

          <!-- Review Vocab -->
          {contentJson.review_vocab?.length > 0 && (
            <div class="bg-blue-50 rounded-2xl p-5">
              <h3 class="text-sm font-semibold text-blue-700 uppercase mb-3">Review Vocabulary</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {contentJson.review_vocab.map((v: any) => (
                  <div class="bg-white rounded-lg px-3 py-2 text-sm">
                    <span class="font-medium text-gray-800">{v.word}</span>
                    <span class="text-gray-500 ml-2">{v.meaning}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Quiz 2 -->
          {contentJson.quiz2 && (
            <Quiz client:load quiz={contentJson.quiz2} id="quiz2" />
          )}

          <!-- Tips -->
          {contentJson.tips && (
            <div class="bg-teal-50 rounded-2xl p-6">
              <h3 class="font-semibold text-teal-800 mb-3">{contentJson.tips.title}</h3>
              <div class="text-gray-700" set:html={formatTips(contentJson.tips.content)} />
            </div>
          )}

          <!-- Conversation -->
          {contentJson.conversation && (
            <div class="bg-white rounded-2xl border border-indigo-100 p-6 shadow-sm">
              <h3 class="text-sm font-semibold text-indigo-700 uppercase mb-2">Conversation</h3>
              <p class="text-gray-500 italic mb-4">{contentJson.conversation.scene}</p>
              <div class="space-y-2" id="convo-display">
                {contentJson.conversation.lines.map((line: any) => (
                  <div class={`flex gap-3 ${line.speaker === 'A' ? '' : 'flex-row-reverse'}`}>
                    <div class={`px-1.5 py-0.5 rounded-full text-xs font-bold ${line.speaker === 'A' ? 'bg-indigo-100 text-indigo-700' : 'bg-orange-100 text-orange-700'}`}>
                      {line.speaker}
                    </div>
                    <div class={`max-w-[80%] px-4 py-2 rounded-2xl text-sm ${line.speaker === 'A' ? 'bg-indigo-50 text-gray-800' : 'bg-orange-50 text-gray-800'}`}>
                      {line.text}
                    </div>
                  </div>
                ))}
              </div>
              <div id="convo-tts" style="display:none">{contentJson.conversation.lines.map((line: any) => `${line.speaker}: ${line.text}`).join(' ... ')}</div>
              <div class="wb-action-row mt-4">
                <button class="wb-action-btn" onclick="copyText('convo-tts')">📋 コピー</button>
                <button class="wb-action-btn wb-tts-btn" onclick="speakText('convo-tts', this)">🔊 読み上げ</button>
                <a class="wb-action-btn" href="https://www.naturalreaders.com/online/" target="_blank" rel="noopener">🔊 Natural Reader</a>
              </div>
            </div>
          )}

          <!-- Conversation Vocab -->
          {contentJson.conversation_vocab?.length > 0 && (
            <div class="bg-blue-50 rounded-2xl p-5">
              <h3 class="text-sm font-semibold text-blue-700 uppercase mb-3">Conversation Vocabulary</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {contentJson.conversation_vocab.map((v: any) => (
                  <div class="bg-white rounded-lg px-3 py-2 text-sm">
                    <span class="font-medium text-gray-800">{v.word}</span>
                    <span class="text-gray-500 ml-2">{v.meaning}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Quiz 3 -->
          {contentJson.quiz3 && (
            <Quiz client:load quiz={contentJson.quiz3} id="quiz3" />
          )}

          <!-- Try It -->
          {contentJson.try_it_hint && (
            <div class="bg-orange-50 rounded-2xl p-6">
              <h3 class="font-semibold text-orange-700 mb-2 text-center">Try It!</h3>
              <p class="text-gray-700 mb-3">{contentJson.try_it_hint}</p>
              <textarea id="tryit-text" class="w-full px-4 py-3 border border-orange-200 rounded-xl text-sm focus:ring-2 focus:ring-orange-300 focus:border-orange-300 outline-none resize-none bg-white" rows={4} placeholder="ここに英語で書いてみよう..." />
            </div>
          )}

          <!-- Summary / ChatGPT -->
          <div class="bg-gray-50 rounded-2xl p-6">
            <h3 class="font-semibold text-gray-700 mb-1">📊 学習サマリー</h3>
            <p class="text-sm text-gray-400 mb-3">ChatGPTやClaudeにコピペして解説をもらおう</p>
            <button id="generate-summary-btn" class="wb-action-btn" style="margin-bottom:0.75rem" onclick="generateSummary()">📋 サマリーを生成する</button>
            <pre id="summary-output" class="hidden whitespace-pre-wrap text-sm text-gray-700 bg-white border border-gray-200 rounded-xl p-4 mb-3 max-h-64 overflow-y-auto"></pre>
            <div id="summary-actions" class="wb-action-row hidden">
              <button class="wb-action-btn" onclick="copySummary()">📋 コピー</button>
              <a class="wb-action-btn" href="https://chat.openai.com" target="_blank" rel="noopener">🤖 ChatGPT</a>
              <a class="wb-action-btn" href="https://claude.ai" target="_blank" rel="noopener">🤖 Claude</a>
            </div>
          </div>
        </div>
      ) : html ? (
        <div class="custom-workbook-content bg-white rounded-2xl border border-gray-200 p-6 md:p-8 shadow-sm">
          <Fragment set:html={html} />
        </div>
      ) : (
        <div class="text-center py-16">
          <div class="text-6xl mb-4">📄</div>
          <p class="text-gray-500">{t(lang, 'customWorkbook.contentNotAvailable')}</p>
        </div>
      )}

      {/* Complete button (multi-day only) */}
      {workbook.total_days > 1 && (
        <div class="mt-8 flex justify-center" id="complete-btn-wrap">
          <button
            id="complete-btn"
            data-workbook-id={workbook.id}
            data-day={dayNum}
            data-completed={isCompleted ? 'true' : 'false'}
            class:list={[
              'px-8 py-3 rounded-full font-semibold text-lg transition-all',
              isCompleted
                ? 'bg-teal-400 text-white'
                : 'border-2 border-dashed border-gray-300 text-gray-500 hover:border-teal-400 hover:text-teal-500',
            ]}
          >
            {isCompleted
              ? `✓ ${t(lang, 'myPortal.dayCompleted')}`
              : t(lang, 'myPortal.markComplete')}
          </button>
        </div>
      )}

      {/* Ask on board */}
      <div class="mt-6 flex justify-center">
        <a
          id="ask-board-btn"
          href={`/board/oshiete/new?title=${encodeURIComponent(`${workbook.title} - Day ${dayNum}`)}&context=${encodeURIComponent(`${workbook.title} Day ${dayNum}`)}`}
          class="inline-flex items-center gap-2 px-6 py-2.5 border border-orange-200 text-orange-500 rounded-full text-sm font-medium hover:bg-orange-50 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {t(lang, 'customWorkbook.askOnBoard')}
        </a>
      </div>

      <div class="flex justify-between mt-8">
        {prevDay ? (
          <a
            href={`/my/workbook/custom/${slug}/day/${prevDay}`}
            class="px-6 py-3 bg-gray-100 text-gray-700 rounded-full font-semibold hover:bg-gray-200 transition-colors"
          >
            ← Day {prevDay}
          </a>
        ) : <div />}
        {nextDay ? (
          <a
            href={`/my/workbook/custom/${slug}/day/${nextDay}`}
            class="px-6 py-3 bg-orange-500 text-white rounded-full font-semibold hover:bg-orange-600 transition-colors"
          >
            Day {nextDay} →
          </a>
        ) : (
          <a
            href={`/my/workbook/custom/${slug}`}
            class="px-6 py-3 bg-teal-500 text-white rounded-full font-semibold hover:bg-teal-600 transition-colors"
          >
            {t(lang, 'customWorkbook.backToGrid')}
          </a>
        )}
      </div>
    </div>
  </section>
</Layout>

<script>
  // --- Complete button ---
  const btn = document.getElementById('complete-btn') as HTMLButtonElement | null;
  if (btn) {
    btn.addEventListener('click', async () => {
      const workbookId = btn.dataset.workbookId;
      const day = parseInt(btn.dataset.day || '0', 10);
      const wasCompleted = btn.dataset.completed === 'true';

      btn.disabled = true;
      try {
        const res = await fetch('/api/custom-workbook/progress', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            workbookId,
            dayNumber: day,
            completed: !wasCompleted,
          }),
        });
        if (res.ok) {
          btn.dataset.completed = wasCompleted ? 'false' : 'true';
          if (!wasCompleted) {
            btn.className = 'px-8 py-3 rounded-full font-semibold text-lg transition-all bg-teal-400 text-white';
            btn.textContent = '✓ 完了済み';
          } else {
            btn.className = 'px-8 py-3 rounded-full font-semibold text-lg transition-all border-2 border-dashed border-gray-300 text-gray-500 hover:border-teal-400 hover:text-teal-500';
            btn.textContent = 'この日を完了にする';
          }
        }
      } finally {
        btn.disabled = false;
      }
    });
  }

  // --- Interactive workbook tools ---
  let currentSpeed = 0.85;

  function copyText(id: string) {
    const el = document.getElementById(id);
    if (!el) return;
    const text = el.textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      const caller = document.activeElement as HTMLButtonElement | null;
      if (caller) {
        const orig = caller.textContent;
        caller.textContent = '✓ コピー済み';
        setTimeout(() => { caller.textContent = orig; }, 1500);
      }
    });
  }

  function speakText(elementId: string, btn: HTMLButtonElement) {
    if (window.speechSynthesis.speaking) {
      window.speechSynthesis.cancel();
      btn.textContent = '🔊 読み上げ';
      btn.classList.remove('wb-tts-playing');
      return;
    }
    const el = document.getElementById(elementId);
    if (!el) return;
    const text = el.textContent || '';
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-AU';
    utterance.rate = currentSpeed;
    utterance.pitch = 1;

    const voices = window.speechSynthesis.getVoices();
    const enVoice = voices.find(v => v.lang.startsWith('en-AU')) ||
                    voices.find(v => v.lang.startsWith('en-GB')) ||
                    voices.find(v => v.lang.startsWith('en'));
    if (enVoice) utterance.voice = enVoice;

    btn.textContent = '⏹ 停止';
    btn.classList.add('wb-tts-playing');

    utterance.onend = () => { btn.textContent = '🔊 読み上げ'; btn.classList.remove('wb-tts-playing'); };
    utterance.onerror = () => { btn.textContent = '🔊 読み上げ'; btn.classList.remove('wb-tts-playing'); };
    window.speechSynthesis.speak(utterance);
  }

  window.speechSynthesis.onvoiceschanged = () => window.speechSynthesis.getVoices();

  function generateSummary() {
    const title = document.title || 'Workbook';
    const tryIt = (document.getElementById('tryit-text') as HTMLTextAreaElement)?.value || '(未記入)';

    let s = `【${title} 学習サマリー】\n\n`;
    s += `■ Try It（自由記述）:\n${tryIt}\n\n`;
    s += `---\n上の内容をもとに、以下を教えてください：\n`;
    s += `1. Try Itの文法・表現の添削（修正箇所の説明付き）\n`;
    s += `2. より自然な言い回しの提案\n`;
    s += `3. 今日の学習内容に関連する追加フレーズ・表現\n`;
    s += `4. 発展的な練習問題（1〜2問）`;

    const output = document.getElementById('summary-output')!;
    const actions = document.getElementById('summary-actions')!;
    output.textContent = s;
    output.classList.remove('hidden');
    actions.classList.remove('hidden');
  }

  function copySummary() {
    const text = document.getElementById('summary-output')?.textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      const caller = document.activeElement as HTMLButtonElement | null;
      if (caller) {
        const orig = caller.textContent;
        caller.textContent = '✓ コピー済み';
        setTimeout(() => { caller.textContent = orig; }, 1500);
      }
    });
  }

  // Expose functions to inline onclick handlers
  (window as any).copyText = copyText;
  (window as any).speakText = speakText;
  (window as any).generateSummary = generateSummary;
  (window as any).copySummary = copySummary;
  (window as any).currentSpeed = currentSpeed;

  // Sync speed selector with global
  document.querySelectorAll('.wb-speed-select').forEach(sel => {
    sel.addEventListener('change', (e) => {
      currentSpeed = parseFloat((e.target as HTMLSelectElement).value);
      (window as any).currentSpeed = currentSpeed;
    });
  });
</script>

<style is:global>
  .custom-workbook-content img {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
  }
  .custom-workbook-content h1,
  .custom-workbook-content h2,
  .custom-workbook-content h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  /* Workbook action buttons */
  .wb-action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .wb-action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.375rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: #374151;
    background: white;
    cursor: pointer;
    transition: all 0.15s;
    text-decoration: none;
  }
  .wb-action-btn:hover {
    background: #f3f4f6;
    border-color: #9ca3af;
  }
  .wb-tts-btn.wb-tts-playing {
    background: #ef4444;
    color: white;
    border-color: #ef4444;
  }
  .wb-tts-btn.wb-tts-playing:hover {
    background: #dc2626;
  }
  .wb-speed-select {
    padding: 0.25rem 0.5rem;
    border: 1px solid #d1d5db;
    border-radius: 0.5rem;
    font-size: 0.7rem;
    color: #6b7280;
    background: white;
    cursor: pointer;
  }
</style>
