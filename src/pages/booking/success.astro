---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';

const user = Astro.locals.user;
const lang = Astro.locals.lang as Lang;

const sessionId = Astro.url.searchParams.get('session_id');
---

<Layout title={t(lang, 'booking.success.paidTitle')} user={user}>
  <section class="py-20 px-4">
    <div class="max-w-md mx-auto text-center">
      <div class="text-6xl mb-6">✅</div>
      <h1 class="text-2xl font-bold text-gray-800 mb-4">
        {t(lang, 'booking.success.paidHeading')}
      </h1>
      <p class="text-gray-600 mb-8">
        {t(lang, 'booking.success.paidMessage')}
      </p>

      <div class="flex flex-col gap-3">
        <a
          href="/my-bookings"
          class="px-6 py-3 bg-orange-500 text-white rounded-xl font-medium hover:bg-orange-600 transition-colors"
        >
          {t(lang, 'booking.success.viewBookings')}
        </a>
        <a
          href="/"
          class="px-6 py-3 text-gray-600 hover:text-gray-800 transition-colors"
        >
          {t(lang, 'booking.success.backToHome')}
        </a>
      </div>
    </div>
  </section>
</Layout>
