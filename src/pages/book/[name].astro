---
import Layout from '../../layouts/Layout.astro';
import GuestBookingFlow from '../../components/booking/GuestBookingFlow';
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';

const { name } = Astro.params;
const lang = Astro.locals.lang as Lang;
const user = Astro.locals.user;

const ALLOWED_HOSTS = ['yuzu'];
if (!ALLOWED_HOSTS.includes(name ?? '')) {
  return Astro.redirect('/');
}

const pageTitle = t(lang, 'booking.guestTitle');
---

<Layout title={pageTitle} user={user}>
  <section class="py-12 px-4">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <div class="w-20 h-20 rounded-full bg-orange-100 flex items-center justify-center mx-auto mb-4 text-3xl">
          🍊
        </div>
        <h1 class="text-2xl font-bold text-gray-800">
          {t(lang, 'booking.hostName')}
        </h1>
        <p class="text-gray-500 text-sm mt-1">
          {t(lang, 'booking.guestSubtitle')}
        </p>
      </div>

      <GuestBookingFlow client:load />
    </div>
  </section>
</Layout>
