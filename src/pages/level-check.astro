---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';

const user = Astro.locals.user;
const lang = Astro.locals.lang as Lang;
---

<Layout title={t(lang, 'levelCheck.title')} description="Discover your Japanese or English level with our text and voice assessment." user={user}>
  <section class="min-h-[60vh] py-20 px-4 flex items-center justify-center">
    <div class="max-w-md mx-auto text-center">
      <span class="text-6xl block mb-6">🚧</span>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">Coming Soon</h1>
      <p class="text-gray-600 leading-relaxed mb-8">
        {lang === 'ja'
          ? 'レベルチェック機能は現在準備中です。もうしばらくお待ちください！'
          : 'The Level Check feature is currently under preparation. Please check back soon!'}
      </p>
      <a href="/" class="inline-block px-6 py-3 bg-orange-500 text-white rounded-full hover:bg-orange-600 transition-colors">
        {lang === 'ja' ? 'トップに戻る' : 'Back to Home'}
      </a>
    </div>
  </section>
</Layout>

