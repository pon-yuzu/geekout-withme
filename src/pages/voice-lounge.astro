---
import Layout from '../layouts/Layout.astro';
import VoiceLounge from '../components/voice-lounge/VoiceLounge.tsx';
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';
import { isPromoActive } from '../lib/promo';
import { isVoiceLoungeAllowed } from '../lib/features';

const user = Astro.locals.user;
const lang = Astro.locals.lang as Lang;
const promoActive = isPromoActive();
const vlEnabled = isVoiceLoungeAllowed(user?.id, Astro.locals);

// When VL is disabled, allow anyone to see the maintenance page (no redirect)
if (vlEnabled && !user && !promoActive) return Astro.redirect('/login');

// Check premium status (only needed when VL is enabled)
let isPremium = false;
let autoLevel: 'beginner' | 'intermediate' | 'advanced' | null = null;

if (vlEnabled && user && Astro.locals.supabase) {
  const supabase = Astro.locals.supabase;
  const { data: subscriptions } = await supabase
    .from('subscriptions')
    .select('status')
    .eq('user_id', user.id)
    .in('status', ['active', 'trialing'])
    .limit(1);
  isPremium = (subscriptions?.length ?? 0) > 0;

  if (promoActive) isPremium = true;

  if (isPremium) {
    try {
      const { data: assessment } = await supabase
        .from('assessment_results')
        .select('text_level')
        .eq('user_id', user.id)
        .order('created_at', { ascending: false })
        .limit(1)
        .single();

      if (assessment?.text_level) {
        const level = assessment.text_level as string;
        if (['A1', 'A2', 'N5', 'N4'].includes(level)) autoLevel = 'beginner';
        else if (['B1', 'B2', 'N3', 'N2'].includes(level)) autoLevel = 'intermediate';
        else if (['C1', 'C2', 'N1'].includes(level)) autoLevel = 'advanced';
      }
    } catch {}
  }
}
---

<Layout title={t(lang, 'voiceLounge.title')} user={user}>
  <section class="py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="text-orange-500">
            {t(lang, 'voiceLounge.title')}
          </span>
        </h1>
        <p class="text-xl text-gray-600">
          {t(lang, 'voiceLounge.subtitle')}
        </p>
      </div>

      {!vlEnabled ? (
        <!-- Maintenance / Coming Soon -->
        <div class="text-center py-16 bg-white border border-gray-200 rounded-2xl p-8 shadow-sm">
          <div class="text-5xl mb-6">🔧</div>
          <p class="text-lg text-gray-600 mb-8 max-w-md mx-auto">
            {t(lang, 'voiceLounge.maintenance.message')}
          </p>
          <div class="flex justify-center items-center gap-5">
            <a href="https://www.instagram.com/rebellious1124/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-orange-500 transition-colors" aria-label="Instagram">
