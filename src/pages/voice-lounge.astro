            </a>
            <a href="https://www.threads.net/@rebellious1124" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-orange-500 transition-colors" aria-label="Threads">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017C1.5 8.418 2.35 5.564 3.995 3.512 5.845 1.208 8.598.027 12.179.003h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.059.564c-1.086-3.898-3.724-5.834-7.835-5.856h-.014c-2.786.02-4.931.928-6.379 2.702C4.945 6.501 4.235 8.912 4.212 12v.012c.023 3.088.733 5.499 2.029 7.023 1.448 1.774 3.593 2.682 6.38 2.702h.006c2.36-.018 4.168-.614 5.531-1.823 1.503-1.334 2.262-3.162 2.255-5.433-.004-1.46-.424-2.638-1.248-3.501-.806-.843-1.929-1.335-3.282-1.47a7.45 7.45 0 00-.197 1.982c.089.04.178.083.266.129 1.418.744 2.137 1.87 2.137 3.348 0 2.453-1.898 4.212-5.07 4.672a8.63 8.63 0 01-1.273.094c-2.278 0-4.088-.884-5.232-2.559-1.073-1.57-1.577-3.703-1.482-5.88.166-3.799 2.088-6.357 5.394-7.03.566-.115 1.157-.173 1.76-.173 1.837 0 3.402.563 4.523 1.629l-1.386 1.612c-.783-.742-1.946-1.135-3.36-1.135-.422 0-.843.041-1.243.121-2.408.49-3.578 2.32-3.698 5.087-.068 1.559.285 3.089.978 4.111.739 1.088 1.847 1.67 3.308 1.67.336 0 .676-.025 1.009-.077 1.842-.266 2.932-1.081 2.932-2.327 0-.574-.27-1.019-.825-1.382a2.66 2.66 0 00-.095 .587c-.009.33-.044.66-.104.984l2.068-.283c.075-.42.113-.848.113-1.279 0-.773-.14-1.49-.404-2.135 2.281.282 3.974 1.293 4.93 2.934.707 1.211 1.073 2.695 1.078 4.356.009 2.939-1.005 5.352-3.015 7.136C18.256 23.14 15.602 23.978 12.186 24z"/></svg>
            </a>
          </div>
        </div>
      ) : isPremium ? (
        <VoiceLounge
          client:load
          userId={user.id}
          userName={user.user_metadata?.display_name || user.email || 'User'}
          isPremium={isPremium}
          autoLevel={autoLevel}
        />
      ) : (
        <div class="text-center py-12 bg-white border border-gray-200 rounded-2xl p-8 shadow-sm">
          <div class="text-4xl mb-4">&#10024;</div>
          <h3 class="text-xl font-medium mb-2 text-gray-800">{t(lang, 'voiceLounge.premium.title')}</h3>
          <p class="text-gray-500 mb-6">
            {t(lang, 'voiceLounge.premium.desc')}
          </p>
          <a
            href="/community"
            class="inline-block px-6 py-3 bg-orange-500 text-white rounded-full font-semibold hover:bg-orange-600 transition-colors"
          >
            {t(lang, 'voiceLounge.premium.button')}
          </a>
        </div>
      )}
    </div>
  </section>
</Layout>
