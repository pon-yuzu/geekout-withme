---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';

const lang = Astro.locals.lang as Lang;
const videoParam = Astro.url.searchParams.get('video') || '';
const ogTitle = t(lang, 'freeSession.ogTitle');
const ogDescription = t(lang, 'freeSession.ogDesc');
---

<Layout
  title={ogTitle}
  description={ogDescription}
>
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 md:py-28 px-4">
    <div class="absolute inset-0 bg-gradient-to-br from-orange-100 via-orange-50 to-teal-50 -z-10"></div>
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-gray-900 leading-tight mb-8">
        {t(lang, 'freeSession.hero.title1')}<br class="hidden md:block" />
        <span class="text-orange-500">{t(lang, 'freeSession.hero.title2')}</span>
      </h1>
      <div class="text-base md:text-lg text-gray-700 leading-relaxed space-y-4 mb-10 max-w-2xl mx-auto text-left md:text-center">
        <p>{t(lang, 'freeSession.hero.p1')}</p>
        <p>{t(lang, 'freeSession.hero.p2')}</p>
        <p>{t(lang, 'freeSession.hero.p3')}</p>
        <p>{t(lang, 'freeSession.hero.p4')}</p>
      </div>
      <a
        href="/booking/free-trial"
        class="inline-block px-8 py-4 bg-orange-500 text-white text-lg font-bold rounded-full hover:bg-orange-600 transition-colors shadow-lg hover:shadow-xl"
      >
        {t(lang, 'freeSession.hero.cta')}
      </a>
    </div>
  </section>

  <!-- About Sayaka -->
  <section class="py-16 md:py-20 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 mb-8">{t(lang, 'freeSession.about.title')}</h2>
      <div class="bg-orange-50 rounded-2xl p-6 md:p-8 border border-orange-100">
        <div class="text-gray-700 leading-relaxed space-y-4">
          <p>{t(lang, 'freeSession.about.bio1')}</p>
          <p>{t(lang, 'freeSession.about.bio2')}</p>
        </div>
        <div class="flex flex-wrap items-center gap-4 mt-6 pt-6 border-t border-orange-200">
          <a
            href="https://x.com/rebellious1124"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-gray-900 text-white rounded-full text-sm hover:bg-gray-700 transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
            @rebellious1124
          </a>
          <a
            href="https://www.youtube.com/@cairsen1000"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-red-600 text-white rounded-full text-sm hover:bg-red-500 transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z" /><polygon fill="#fff" points="9.545,15.568 15.818,12 9.545,8.432" /></svg>
            Uchiwai
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Video -->
  <section class="py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 mb-8">{t(lang, 'freeSession.video.title')}</h2>
      <div id="yt-container" class="relative w-full rounded-2xl overflow-hidden shadow-lg bg-gray-900" style="aspect-ratio: 16/9;">
        {videoParam ? (
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${videoParam}?rel=0`}
            title="YouTube video"
            class="absolute inset-0 w-full h-full"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        ) : (
          <div class="absolute inset-0 flex flex-col items-center justify-center text-white/60">
            <svg class="w-16 h-16 mb-3" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z" /><polygon fill="#fff" points="9.545,15.568 15.818,12 9.545,8.432" /></svg>
            <p class="text-sm">{t(lang, 'freeSession.video.placeholder')}</p>
          </div>
        )}
      </div>
      <p class="text-center text-sm text-gray-500 mt-3">※ {t(lang, 'freeSession.video.note')}</p>
    </div>
  </section>

  <!-- Session Details -->
  <section class="py-16 md:py-20 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 mb-4">
        {t(lang, 'freeSession.session.title')}<span class="text-teal-500">{t(lang, 'freeSession.session.titleAccent')}</span>
      </h2>
      <div class="text-gray-700 leading-relaxed space-y-4 mb-8 text-center">
        <p>{t(lang, 'freeSession.session.intro')}</p>
        <div class="bg-teal-50 rounded-2xl p-6 text-left space-y-3 border border-teal-100">
          <p class="font-semibold text-teal-700">{t(lang, 'freeSession.session.step1')}</p>
          <p class="font-semibold text-teal-700">{t(lang, 'freeSession.session.step2')}</p>
        </div>
        <p>{t(lang, 'freeSession.session.conclusion')}</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-orange-50 rounded-xl p-4 text-center border border-orange-100">
          <span class="text-2xl block mb-1">⏱</span>
          <p class="text-xs text-gray-500 mb-1">{t(lang, 'freeSession.session.durationLabel')}</p>
          <p class="font-bold text-gray-800">{t(lang, 'freeSession.session.durationValue')}</p>
        </div>
        <div class="bg-orange-50 rounded-xl p-4 text-center border border-orange-100">
          <span class="text-2xl block mb-1">💻</span>
          <p class="text-xs text-gray-500 mb-1">{t(lang, 'freeSession.session.formatLabel')}</p>
          <p class="font-bold text-gray-800">{t(lang, 'freeSession.session.formatValue')}</p>
        </div>
        <div class="bg-orange-50 rounded-xl p-4 text-center border border-orange-100">
          <span class="text-2xl block mb-1">👥</span>
          <p class="text-xs text-gray-500 mb-1">{t(lang, 'freeSession.session.capacityLabel')}</p>
          <p class="font-bold text-gray-800">{t(lang, 'freeSession.session.capacityValue')}</p>
        </div>
        <div class="bg-orange-50 rounded-xl p-4 text-center border border-orange-100">
          <span class="text-2xl block mb-1">💰</span>
          <p class="text-xs text-gray-500 mb-1">{t(lang, 'freeSession.session.priceLabel')}</p>
          <p class="font-bold text-orange-500 text-lg">{t(lang, 'freeSession.session.priceValue')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Free -->
  <section class="py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 mb-8">{t(lang, 'freeSession.whyFree.title')}</h2>
      <div class="bg-white rounded-2xl p-6 md:p-8 border border-orange-100 shadow-sm">
        <div class="text-gray-700 leading-relaxed space-y-4">
          <p>{t(lang, 'freeSession.whyFree.p1')}</p>
          <p>{t(lang, 'freeSession.whyFree.p2')}</p>
          <p>{t(lang, 'freeSession.whyFree.p3')}</p>
          <p class="font-semibold text-gray-900">{t(lang, 'freeSession.whyFree.p4')}</p>
          <p class="text-orange-600 font-bold">{t(lang, 'freeSession.whyFree.p5')}</p>
          <p>{t(lang, 'freeSession.whyFree.p6')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 leading-relaxed mb-10">
        {t(lang, 'freeSession.cta.title1')}<br />
        {t(lang, 'freeSession.cta.title2')}<br />
        <span class="text-orange-500">{t(lang, 'freeSession.cta.title3')}</span>
      </h2>
      <a
        href="/booking/free-trial"
        class="inline-block px-10 py-5 bg-orange-500 text-white text-xl font-bold rounded-full hover:bg-orange-600 transition-colors shadow-lg hover:shadow-xl"
      >
        {t(lang, 'freeSession.cta.button')}
      </a>
      <p class="text-sm text-gray-500 mt-4">
        {t(lang, 'freeSession.cta.note')}
      </p>
    </div>
  </section>

  <!-- June Event Preview -->
  <section class="py-16 md:py-20 px-4 bg-gradient-to-br from-gray-900 to-gray-800">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-teal-400 font-bold text-sm tracking-widest mb-4">{t(lang, 'freeSession.event.date')}</p>
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
        {t(lang, 'freeSession.event.title')}
      </h2>
      <p class="text-gray-300 mb-8">{t(lang, 'freeSession.event.desc')}<br />{t(lang, 'freeSession.event.descSub')}</p>
      <span
        class="inline-block px-8 py-4 border-2 border-gray-500 text-gray-500 font-bold rounded-full cursor-not-allowed opacity-60"
      >
        {t(lang, 'freeSession.event.button')}
      </span>
    </div>
  </section>
</Layout>
