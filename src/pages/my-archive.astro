---
import Layout from '../layouts/Layout.astro';
import LessonArchive from '../components/lesson-archive/LessonArchive';
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';
import { getUserTier } from '../lib/tier';
import { isAdmin as checkAdmin } from '../lib/admin';

const user = Astro.locals.user;
const lang = Astro.locals.lang as Lang;

if (!user) {
  return Astro.redirect('/login');
}

const supabase = Astro.locals.supabase!;
const userTier = await getUserTier(supabase, user.id);
const admin = checkAdmin(user.email, Astro.locals);

// Only personal tier users and admins can access
if (userTier !== 'personal' && !admin) {
  return Astro.redirect('/');
}

const pageTitle = lang === 'ja' ? 'レッスンアーカイブ' : 'Lesson Archive';
---

<Layout title={pageTitle} user={user}>
  <section class="py-12 px-4 max-w-3xl mx-auto">
    <div class="text-center mb-8">
      <span class="text-3xl">📦</span>
      <h1 class="text-2xl font-bold text-gray-800 mt-2">{pageTitle}</h1>
      <p class="text-gray-500 text-sm mt-1">
        {lang === 'ja' ? 'セッション資料やファイルを管理' : 'Manage your session files and materials'}
      </p>
    </div>

    <LessonArchive
      client:load
      studentId={user.id}
      userId={user.id}
      isAdmin={admin}
    />
  </section>
</Layout>
