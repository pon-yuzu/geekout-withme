---
import Layout from '../../../layouts/Layout.astro';

const user = Astro.locals.user;
const isLoggedIn = !!user;
---

<Layout title="ご購入ありがとうございます" user={user}>
  <section class="py-12 px-4">
    <div class="max-w-xl mx-auto">
      <!-- Loading state -->
      <div id="loading" class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm text-center">
        <span class="text-5xl block mb-4">⏳</span>
        <h1 class="text-2xl font-bold mb-2">購入情報を確認中...</h1>
        <p class="text-gray-500">少々お待ちください</p>
      </div>

      <!-- Success state (hidden by default) -->
      <div id="success" class="hidden">
        <div class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm text-center">
          <span class="text-5xl block mb-4">🎉</span>
          <h1 class="text-2xl font-bold mb-2">ご購入ありがとうございます！</h1>
          <p class="text-gray-600 mb-6">
            <span id="customer-name-display"></span>さん、コースのアクセス情報をお届けします。
          </p>

          <div class="bg-orange-50 border border-orange-200 rounded-xl p-6 mb-6 text-left">
            <p class="text-sm text-gray-600 mb-1">パスワード</p>
            <p id="password-display" class="text-2xl font-bold text-orange-500 tracking-wider mb-4"></p>

            <p class="text-sm text-gray-600 mb-1">コースページ</p>
            <a id="course-link" href="#" class="text-blue-600 hover:underline font-medium block mb-4"></a>

            <p class="text-sm text-gray-600 mb-1">アクセス期間</p>
            <p id="access-period" class="font-medium text-gray-800"></p>
          </div>

          <p class="text-sm text-gray-500 mb-4">
            コースページの「パスワード入力」ボタンから上記パスワードを入力すると、全Dayにアクセスできます。
            パスワードはメールにも送信されています。
          </p>

          <a id="course-btn" href="#" class="inline-block px-6 py-3 bg-orange-500 text-white rounded-full font-semibold hover:bg-orange-600 transition-colors">
            コースを開く
          </a>
        </div>

        <!-- Free account registration CTA (only for non-logged-in users) -->
        <div id="signup-cta" class={isLoggedIn ? 'hidden' : 'mt-6 bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 rounded-2xl p-6'}>
          <div class="text-center mb-4">
            <span class="text-4xl block mb-2">🆙</span>
            <h2 class="text-xl font-bold text-gray-800">無料会員登録でアクセス期間を1年に延長！</h2>
            <p class="text-gray-600 text-sm mt-2">
              現在のアクセス期間は6ヶ月です。無料会員登録するだけで1年に延長されます。
            </p>
          </div>

          <ul class="text-sm text-gray-600 space-y-2 mb-5">
            <li class="flex items-center gap-2"><span class="text-green-500">✓</span> ワークブックのアクセス期間が1年に延長</li>
            <li class="flex items-center gap-2"><span class="text-green-500">✓</span> AI Workbook（パーソナライズ学習）が使える</li>
            <li class="flex items-center gap-2"><span class="text-green-500">✓</span> レベルチェック結果の保存</li>
            <li class="flex items-center gap-2"><span class="text-green-500">✓</span> コミュニティ・掲示板への参加</li>
          </ul>

          <a
            id="signup-link"
            href="/signup"
            class="block w-full py-3 bg-green-600 text-white rounded-full font-semibold hover:bg-green-700 transition-colors text-center"
          >
            無料会員登録する（30秒で完了）
          </a>
        </div>

        <!-- Already logged in confirmation -->
        <div id="account-confirmed" class={isLoggedIn ? 'mt-6 bg-green-50 border border-green-200 rounded-xl p-4 text-center' : 'hidden'}>
          <span class="text-sm text-green-700 font-medium">✓ 会員登録済み — 1年間アクセス可能です</span>
        </div>
      </div>

      <!-- Error state (hidden by default) -->
      <div id="error-state" class="hidden bg-white border border-gray-200 rounded-2xl p-8 shadow-sm text-center">
        <span class="text-5xl block mb-4">⚠️</span>
        <h1 class="text-2xl font-bold mb-2">購入情報の取得に失敗しました</h1>
        <p class="text-gray-600 mb-6">メールでパスワードをお送りしていますのでご確認ください。</p>
        <a href="/workbook" class="inline-block px-6 py-3 bg-orange-500 text-white rounded-full font-semibold hover:bg-orange-600 transition-colors">
          ワークブックページへ
        </a>
      </div>
    </div>
  </section>
</Layout>

<script is:inline define:vars={{ isLoggedIn }}>
(async function() {
  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get('session_id');

  if (!sessionId) {
    document.getElementById('loading').classList.add('hidden');
    document.getElementById('error-state').classList.remove('hidden');
    return;
  }

  try {
    const res = await fetch('/api/stripe-session?session_id=' + encodeURIComponent(sessionId));
    if (!res.ok) throw new Error('API error');

    const data = await res.json();
    const { customerName, courseId, password, baseUrl, courseTitle } = data;

    // Save to localStorage
    localStorage.setItem('uchiwai_course_access_' + courseId, 'true');
    localStorage.setItem('uchiwai_course_purchased_at_' + courseId, new Date().toISOString());
    if (customerName) {
      localStorage.setItem('uchiwai_course_name_' + courseId, customerName);
    }
    if (isLoggedIn) {
      localStorage.setItem('uchiwai_course_has_account_' + courseId, 'true');
    }

    // Update UI
    var nameDisplay = document.getElementById('customer-name-display');
    nameDisplay.textContent = customerName || 'ゲスト';

    document.getElementById('password-display').textContent = password;

    var courseLink = document.getElementById('course-link');
    courseLink.href = baseUrl;
    courseLink.textContent = 'https://uchiwai.app' + baseUrl;

    document.getElementById('course-btn').href = baseUrl;

    var accessPeriod = document.getElementById('access-period');
    accessPeriod.textContent = isLoggedIn
      ? '購入から1年間'
      : '購入から6ヶ月（無料会員登録で1年に延長）';

    // Update signup CTA link with redirect back to this page
    var signupLink = document.getElementById('signup-link');
    if (signupLink) {
      signupLink.href = '/signup?redirect=' + encodeURIComponent(window.location.pathname + window.location.search);
    }

    document.getElementById('loading').classList.add('hidden');
    document.getElementById('success').classList.remove('hidden');
  } catch (err) {
    console.error('Thanks page error:', err);
    document.getElementById('loading').classList.add('hidden');
    document.getElementById('error-state').classList.remove('hidden');
  }
})();
</script>
