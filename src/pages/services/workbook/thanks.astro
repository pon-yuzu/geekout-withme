---
import Layout from '../../../layouts/Layout.astro';
import { t } from '../../../i18n/index';
import type { Lang } from '../../../i18n/index';
import { getUserTier } from '../../../lib/tier';
import { hasLineSupport } from '../../../lib/line-support';

const user = Astro.locals.user;
const lang = Astro.locals.lang as Lang;

let showLineUpsell = false;
if (user && Astro.locals.supabase) {
  const runtime = (Astro.locals as any).runtime;
  const linePriceId = runtime?.env?.STRIPE_LINE_SUPPORT_PRICE_ID || import.meta.env.STRIPE_LINE_SUPPORT_PRICE_ID;
  if (linePriceId) {
    const tier = await getUserTier(Astro.locals.supabase, user.id);
    showLineUpsell = !(await hasLineSupport(Astro.locals.supabase, user.id, tier, linePriceId));
  }
}
---

<Layout title={t(lang, 'services.thanks.workbook.title')} user={user}>
  <section class="py-12 px-4">
    <div class="max-w-xl mx-auto">
      <div class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm text-center">
        <span class="text-5xl block mb-4">📘</span>
        <h1 class="text-2xl font-bold mb-2">{t(lang, 'services.thanks.workbook.title')}</h1>
        <p class="text-gray-600 mb-8">{t(lang, 'services.thanks.workbook.subtitle')}</p>

        <form id="workbook-form" class="text-left space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{t(lang, 'services.thanks.workbook.name')}</label>
            <input type="text" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{t(lang, 'services.thanks.workbook.email')}</label>
            <input type="email" name="email" required value={user?.email || ''} class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{t(lang, 'services.thanks.workbook.deadline')}</label>
            <input type="date" name="deadline" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent" />
          </div>
          <button
            type="submit"
            class="w-full px-6 py-3 bg-orange-500 text-white rounded-full font-semibold hover:bg-orange-600 transition-colors disabled:opacity-50"
          >
            {t(lang, 'services.thanks.workbook.submit')}
          </button>
          <p id="form-status" class="text-center text-sm text-green-600 hidden"></p>
        </form>
      </div>

      {showLineUpsell && (
        <div class="mt-6 bg-gradient-to-br from-teal-50 to-emerald-50 border border-teal-200 rounded-2xl p-6">
          <div class="text-center mb-4">
            <span class="text-4xl block mb-2">💬</span>
            <h2 class="text-xl font-bold text-gray-800">
              {t(lang, 'services.lineUpsell.title')}
            </h2>
            <p class="text-gray-600 text-sm mt-2">
              {t(lang, 'services.lineUpsell.desc')}
            </p>
          </div>

          <div class="bg-white rounded-xl p-4 mb-4 text-center">
            <p class="text-3xl font-bold text-teal-500">¥5,000<span class="text-base font-normal text-gray-400">/月</span></p>
          </div>

          <ul class="text-sm text-gray-600 space-y-2 mb-5">
            <li class="flex items-center gap-2"><span class="text-teal-400">✓</span>{t(lang, 'services.lineUpsell.feature1')}</li>
            <li class="flex items-center gap-2"><span class="text-teal-400">✓</span>{t(lang, 'services.lineUpsell.feature2')}</li>
            <li class="flex items-center gap-2"><span class="text-teal-400">✓</span>{t(lang, 'services.lineUpsell.feature3')}</li>
          </ul>

          <button
            id="line-upsell-btn"
            data-label={t(lang, 'services.lineUpsell.cta')}
            data-processing={t(lang, 'services.lineUpsell.processing')}
            class="w-full py-3 bg-teal-500 text-white rounded-full font-semibold hover:bg-teal-600 transition-colors disabled:opacity-50"
          >
            {t(lang, 'services.lineUpsell.cta')}
          </button>
          <p class="text-xs text-gray-400 text-center mt-2">
            {t(lang, 'services.lineUpsell.cancelNote')}
          </p>
        </div>
      )}
    </div>
  </section>
</Layout>

<script is:inline>
  document.getElementById('workbook-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    const status = document.getElementById('form-status');
    btn.disabled = true;
    btn.textContent = btn.dataset.sending || 'Sending...';

    try {
      const data = new FormData(form);
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.get('name'),
          email: data.get('email'),
          category: 'workbook-order',
          message: 'Preferred delivery date: ' + (data.get('deadline') || 'Not specified'),
        }),
      });
      if (res.ok) {
        status.textContent = status.dataset.sent || 'Form submitted! We\'ll be in touch soon.';
        status.classList.remove('hidden');
        form.reset();
      }
    } catch (err) {
      console.error(err);
    }
    btn.disabled = false;
    btn.textContent = btn.dataset.label || 'Submit';
  });

  document.getElementById('line-upsell-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget;
    btn.disabled = true;
    btn.textContent = btn.dataset.processing || 'Processing...';
    try {
      const res = await fetch('/api/create-line-support-checkout', { method: 'POST' });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
        return;
      }
    } catch (err) {
      console.error(err);
    }
    btn.disabled = false;
    btn.textContent = btn.dataset.label || 'Add LINE Support Now';
  });
</script>
